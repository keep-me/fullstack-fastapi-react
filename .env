DOMAIN=localhost
PYTHONPATH=./backend

COMPOSE_BAKE=true

ENVIRONMENT=production

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=2
SERVER_RELOAD=false

POSTGRES_SERVER=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
PGADMIN_CONFIG_SERVER_MODE=False

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT=5
CACHE_EXPIRE_SECONDS=86400

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
RABBITMQ_VHOST=/
RABBITMQ_CONFIG_FILE=/etc/rabbitmq/rabbitmq.conf

SECRET_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=10
REFRESH_TOKEN_EXPIRE_MINUTES=432000

FIRST_SUPERUSER_USERNAME=
FIRST_SUPERUSER_EMAIL=
FIRST_SUPERUSER_PASSWORD=
FIRST_SUPERUSER_NAME=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

BACKEND_CORS_ORIGINS=
FRONTEND_HOST=http://localhost:5173,http://localhost

SENTRY_DSN=
LOG_LEVEL=WARNING

GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=
GF_LOG_LEVEL=warn

LOAD_TEST_HOST=https://api.example.com
LOAD_TEST_USERS=20
LOAD_TEST_SPAWN_RATE=3
LOAD_TEST_DURATION=5m